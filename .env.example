# ──────────────────────────────────────────────
#  Email Agent – Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── Email Credentials ─────────────────────────
# Provider: "gmail" | "imap"
EMAIL_PROVIDER=gmail

# Your full email address
EMAIL_ADDRESS=you@gmail.com

# Gmail App Password (16-char, no spaces) OR your IMAP password.
# To create a Gmail App Password:
#   https://myaccount.google.com/apppasswords
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── IMAP Settings (only needed when EMAIL_PROVIDER=imap) ──
IMAP_HOST=imap.example.com
IMAP_PORT=993

# ── LLM Settings (ALL OPTIONS ARE FREE) ───────
# Choose ONE provider and fill in only that section.
#
#   ollama  → runs locally on your PC, totally free, no internet needed
#   gemini  → Google Gemini 2.0 Flash, free tier (no card required)
#   groq    → Groq Cloud (Llama-3), free tier (no card required)
#
LLM_PROVIDER=ollama

# ── Option A: Ollama (recommended – 100% free & offline) ──
# Install from https://ollama.com, then run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Option B: Google Gemini (free API) ────────
# Free tier: 15 RPM · 1 500 requests/day · 1 M tokens/day — no billing needed
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# gemini-2.0-flash-lite has 30 RPM free (double the regular flash limit)
GEMINI_MODEL=gemini-2.0-flash-lite

# ── Option C: Groq Cloud (free API) ───────────
# Free tier: 14 400 requests/day on Llama-3-8B / Mixtral — no billing needed
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# ── Notification Settings ─────────────────────
# Provider: "telegram" | "discord"
NOTIFICATION_PROVIDER=telegram

# Telegram Bot Token – obtained from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff

# Your Telegram chat ID – send any message to your bot then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=987654321

# Discord Webhook URL – created in Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Scheduler Settings ────────────────────────
# Times to run (24-hour format, comma-separated)
SCHEDULE_TIMES=08:00,20:00

# Your local timezone (IANA format) – https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Kolkata

# ── Email Processing ──────────────────────────
# How many hours back to look for unread emails
LOOKBACK_HOURS=12

# Max emails to process per run — prevents large backlogs hammering the LLM.
# The most recent N emails within the window are kept; older ones are skipped.
MAX_EMAILS_PER_RUN=20

# Gmail label to apply after processing (set to "" to skip labelling)
GMAIL_PROCESSED_LABEL=Processed_by_Agent

# Maximum body characters sent to LLM per email
MAX_BODY_CHARS=2000
